# Local development — copy to .env and adjust

ENVIRONMENT=development
LOG_LEVEL=INFO

# Database (local Postgres)
DATABASE_URL=postgresql+asyncpg://kagenou:kagenou@localhost:5432/peer_rendering

# Or use Secrets Manager on EC2
# DATABASE_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789:secret:fam/db
# AUTH_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789:secret:fam/auth

# Bearer tokens for local dev (prod: Secrets Manager JSON)
# Service token (admin/API): no user_id
BEARER_TOKENS_JSON=[{"id":"dev","token":"your-dev-token-here","type":"service"},{"id":"user-dev","token":"your-user-token-here","type":"user","user_id":"PASTE-USER-UUID-HERE"}]

# Dashboard /me/profile: dev fallback if token has no user_id (development only)
ALLOW_DEV_USER_ID_HEADER=true
# JWT_SECRET=change-me-when-login-ships

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=0
DB_QUERY_TIMEOUT_MS=150

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

CLOUDWATCH_ENABLED=false
AWS_REGION=ap-southeast-1
