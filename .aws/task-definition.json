{
    "family": "fam-deploy-dev",
    "containerDefinitions": [
        {
            "name": "fam-backend",
            "image": "382535610141.dkr.ecr.ap-south-1.amazonaws.com/fam-backend:90332d07300dbd407907ed9bf7c505208063ecc1",
            "cpu": 0,
            "memory": 2048,
            "portMappings": [
                {
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp",
                    "name": "container-port-protocol",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "AWS_REGION",
                    "value": "ap-south-1"
                },
                {
                    "name": "DATABASE_SECRET_ARN",
                    "value": "arn:aws:secretsmanager:ap-south-1:382535610141:secret:fam_deva"
                },
                {
                    "name": "AUTH_SECRET_ARN",
                    "value": "arn:aws:secretsmanager:ap-south-1:382535610141:secret:fam_auth_token"
                },
                {
                    "name": "LIMIT_BYPASS_SECRET_ARN",
                    "value": "arn:aws:secretsmanager:ap-south-1:382535610141:secret:fam_rate_limit_bypass_token"
                },
                {
                    "name": "LOG_LEVEL",
                    "value": "INFO"
                },
                {
                    "name": "ENVIRONMENT",
                    "value": "development"
                },
                {
                    "name": "DB_POOL_SIZE",
                    "value": "50"
                },
                {
                    "name": "DB_MAX_OVERFLOW",
                    "value": "20"
                },
                {
                    "name": "DB_QUERY_TIMEOUT_MS",
                    "value": "300"
                },
                {
                    "name": "RATE_LIMIT_BYPASS_TOKEN,",
                    "value": "45c11852-ffa6-4193-a25a-ee71a9fc05e7"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/fam-deploy-dev",
                    "awslogs-create-group": "true",
                    "awslogs-region": "ap-south-1",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "healthCheck": {
                "command": [
                    "CMD-SHELL",
                    "curl -f http://localhost:8080/health || exit 1"
                ],
                "interval": 60,
                "timeout": 5,
                "retries": 3
            },
            "systemControls": []
        }
    ],
    "taskRoleArn": "arn:aws:iam::382535610141:role/ecsTaskExecutionRole",
    "executionRoleArn": "arn:aws:iam::382535610141:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "2048",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    }
}